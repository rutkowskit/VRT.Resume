<PageTitle>Resumes</PageTitle>

<MudStack Spacing="4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Resumes</MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddAsync">
            Add resume
        </MudButton>
    </MudStack>

    <MudText Typo="Typo.body1" Class="mud-text-secondary">
        Manage resume variants for the active profile.
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_resumes.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No resumes yet. Create your first resume variant.
        </MudAlert>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddAsync">
            Add resume
        </MudButton>
    }
    else
    {
        <MudTable Items="_resumes" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Description</MudTh>
                <MudTh>Position</MudTh>
                <MudTh>Modified</MudTh>
                <MudTh Style="width: 200px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Description">
                    <MudLink Href="@ResumeDisplayHelpers.ShowUrl(context.ResumeId)">@context.Description</MudLink>
                </MudTd>
                <MudTd DataLabel="Position">@context.Position</MudTd>
                <MudTd DataLabel="Modified">@context.ModifiedDate.ToString("yyyy-MM-dd HH:mm")</MudTd>
                <MudTd DataLabel="Actions">
                    <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Size="Size.Small"
                                       Title="View"
                                       Href="@ResumeDisplayHelpers.ShowUrl(context.ResumeId)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Title="Edit"
                                       OnClick="@(() => EditAsync(context.ResumeId))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Workspaces"
                                       Size="Size.Small"
                                       Title="Skills"
                                       OnClick="@(() => EditSkillsAsync(context.ResumeId))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                       Size="Size.Small"
                                       Title="Clone"
                                       OnClick="@(() => CloneAsync(context.ResumeId, context.Description))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       Title="Delete"
                                       OnClick="@(() => DeleteAsync(context.ResumeId, context.Description))" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>