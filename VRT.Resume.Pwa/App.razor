@using VRT.Resume.Pwa.Components

@if (Startup.HasError)
{
    <StartupErrorView />
}
else if (Startup.IsReady)
{
    <AppThemeProvider />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <CultureBootstrap />
    <ThemeBootstrap />

    <Router @key="_cultureKey" AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <ProfileRequiredRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
}