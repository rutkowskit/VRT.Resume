<MudStack Spacing="3" Class="mt-2">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddAsync">
        Add contact
    </MudButton>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!string.IsNullOrEmpty(_loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
    }
    else if (_items.Length == 0)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">No contacts yet.</MudText>
    }
    else
    {
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            @foreach (var item in _items)
            {
                <MudPaper Class="pa-4" Elevation="0" Outlined="true" Style="min-width: 260px;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <MudText Typo="Typo.h6">@item.Name</MudText>
                        <EditDeleteToolbar OnEdit="@(() => EditAsync(item.ContactId))"
                                           OnDelete="@(() => DeleteAsync(item.ContactId, item.Name))" />
                    </MudStack>
                    <MudText Typo="Typo.body2">@item.Value</MudText>
                </MudPaper>
            }
        </MudStack>
    }
</MudStack>