@using VRT.Resume.Application.Persons.Commands.UpdatePersonData
@using VRT.Resume.Application.Persons.Queries.GetPersonData
@inject MediatorSender Mediator

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
}
else if (!string.IsNullOrEmpty(_loadError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-2">@_loadError</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mt-2" Elevation="0" Outlined="true">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">Basic data</MudText>

        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_firstName"
                              Label="First name"
                              Required="true"
                              RequiredError="First name is required"
                              MaxLength="50"
                              Immediate="true"
                              Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.FirstName))"
                              ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.FirstName))" />
                <MudTextField @bind-Value="_lastName"
                              Label="Last name"
                              MaxLength="100"
                              Immediate="true"
                              Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.LastName))"
                              ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.LastName))" />
                <MudDatePicker @bind-Date="_dateOfBirth"
                               Label="Date of birth"
                               Clearable="true"
                               DateFormat="yyyy-MM-dd" />
            </MudStack>
        </MudForm>

        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_saving || !_isValid)"
                       OnClick="SaveAsync">
                @(_saving ? "Saving…" : "Save")
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _loading = true;
    private bool _saving;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private DateTime? _dateOfBirth;
    private string? _loadError;
    private IReadOnlyDictionary<string, string[]> _fieldErrors = new Dictionary<string, string[]>();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        var outcome = await Mediator.SendAsync(
            new GetPersonDataQuery(),
            new MediatorSendOptions { NotifyOnFailure = true });

        if (outcome.Result.IsFailure)
        {
            _loadError = outcome.Result.Error;
            _loading = false;
            return;
        }

        _firstName = outcome.Result.Value.FirstName;
        _lastName = outcome.Result.Value.LastName;
        _dateOfBirth = outcome.Result.Value.DateOfBirth;
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid)
                return;
        }

        _saving = true;
        _fieldErrors = new Dictionary<string, string[]>();

        var outcome = await Mediator.SendAsync(
            new UpdatePersonDataCommand
            {
                FirstName = _firstName.Trim(),
                LastName = _lastName.Trim(),
                DateOfBirth = _dateOfBirth,
            },
            new MediatorSendOptions { NotifyOnSuccess = true });

        _fieldErrors = outcome.FieldErrors;
        _saving = false;
    }
}