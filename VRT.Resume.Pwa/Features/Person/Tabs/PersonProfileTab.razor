@inherits CultureAwareComponentBase
@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
}
else if (!string.IsNullOrEmpty(_loadError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-2">@_loadError</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mt-2" Elevation="0" Outlined="true">
        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center" Class="mb-4">
            <MudAvatar Style="width: 96px; height: 96px;">
                <MudImage Src="@_imageUrl" Alt="@LabelNames.PersonImagePageTitle.GetLabelText()" ObjectFit="ObjectFit.Cover" />
            </MudAvatar>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PhotoCamera"
                       Href="@Routes.Persons.Image">
                @LabelNames.ButonChangeImg.GetLabelText()
            </MudButton>
        </MudStack>

        <MudText Typo="Typo.subtitle1" GutterBottom="true">@LabelNames.MainInfo.GetLabelText()</MudText>

        <MudForm @ref="_form" @bind-IsValid="_isValid" ValidationDelay="0">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_firstName"
                              @bind-Value:after="OnFieldChangedAsync"
                              Label="@LabelNames.FirstName.GetLabelText()"
                              Required="true"
                              RequiredError="@LabelNames.FirstNameRequired.GetLabelText()"
                              MaxLength="50"
                              Immediate="true"
                              Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.FirstName))"
                              ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.FirstName))" />
                <MudTextField @bind-Value="_lastName"
                              @bind-Value:after="OnFieldChangedAsync"
                              Label="@LabelNames.LastName.GetLabelText()"
                              Required="true"
                              MaxLength="100"
                              Immediate="true"
                              Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.LastName))"
                              ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpdatePersonDataCommand.LastName))" />
                <MudDatePicker @bind-Date="_dateOfBirth"
                               @bind-Date:after="OnFieldChangedAsync"
                               Label="@LabelNames.DateOfBirth.GetLabelText()"
                               Clearable="true"
                               DateFormat="yyyy-MM-dd" />
            </MudStack>
        </MudForm>

        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_saving || !_isValid)"
                       OnClick="SaveAsync">
                @(_saving ? LabelNames.StatusSaving.GetLabelText() : LabelNames.ButtonSave.GetLabelText())
            </MudButton>
        </MudStack>
    </MudPaper>
}
