<MudDialog DefaultFocus="DefaultFocus.FirstChild" DisableBackdropClick="true">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isNew ? "Add contact" : "Edit contact")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_name" Label="Name" Required="true" MaxLength="100" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Name))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Name))" />
                    <MudTextField @bind-Value="_value" Label="Value" Required="true" MaxLength="200" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Value))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Value))" />
                    <MudTextField @bind-Value="_url" Label="URL" MaxLength="500" Immediate="true" />
                    <MudTextField @bind-Value="_icon" Label="Icon (SVG/HTML)" Lines="3" MaxLength="5000" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Icon))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Icon))" />
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_saving || _loading || !_isValid)" OnClick="SaveAsync">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>