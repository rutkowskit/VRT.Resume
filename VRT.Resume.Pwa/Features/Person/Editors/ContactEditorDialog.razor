@using VRT.Resume.Application.Persons.Commands.UpsertPersonContact
@using VRT.Resume.Application.Persons.Queries.GetPersonContacts
@inject MediatorSender Mediator

<MudDialog DefaultFocus="DefaultFocus.FirstChild" DisableBackdropClick="true">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isNew ? "Add contact" : "Edit contact")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_name" Label="Name" Required="true" MaxLength="100" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Name))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Name))" />
                    <MudTextField @bind-Value="_value" Label="Value" Required="true" MaxLength="200" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Value))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Value))" />
                    <MudTextField @bind-Value="_url" Label="URL" MaxLength="500" Immediate="true" />
                    <MudTextField @bind-Value="_icon" Label="Icon (SVG/HTML)" Lines="3" MaxLength="5000" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Icon))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonContactCommand.Icon))" />
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_saving || _loading || !_isValid)" OnClick="SaveAsync">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int ContactId { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private bool _loading = true;
    private bool _saving;
    private bool _isNew => ContactId == 0;

    private string _name = string.Empty;
    private string _value = string.Empty;
    private string _url = string.Empty;
    private string _icon = string.Empty;
    private IReadOnlyDictionary<string, string[]> _fieldErrors = new Dictionary<string, string[]>();

    protected override async Task OnInitializedAsync()
    {
        if (_isNew)
        {
            _loading = false;
            return;
        }

        var outcome = await Mediator.SendAsync(
            new GetPersonContactQuery { ContactId = ContactId },
            new MediatorSendOptions { NotifyOnFailure = true });

        if (outcome.Result.IsFailure)
        {
            MudDialog.Cancel();
            return;
        }

        var item = outcome.Result.Value;
        _name = item.Name;
        _value = item.Value;
        _url = item.Url ?? string.Empty;
        _icon = item.Icon ?? string.Empty;
        _loading = false;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid)
                return;
        }

        _saving = true;
        _fieldErrors = new Dictionary<string, string[]>();

        var outcome = await Mediator.SendAsync(
            new UpsertPersonContactCommand
            {
                ContactId = ContactId,
                Name = _name.Trim(),
                Value = _value.Trim(),
                Url = _url.Trim(),
                Icon = _icon.Trim(),
            },
            new MediatorSendOptions { NotifyOnSuccess = true });

        _fieldErrors = outcome.FieldErrors;
        _saving = false;

        if (outcome.Result.IsSuccess)
            MudDialog.Close(DialogResult.Ok(true));
    }
}