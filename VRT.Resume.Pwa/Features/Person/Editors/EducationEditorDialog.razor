<MudDialog DefaultFocus="DefaultFocus.FirstChild" DisableBackdropClick="true">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isNew ? LabelNames.AddEducationTitle.GetLabelText() : LabelNames.EditEducationTitle.GetLabelText())</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_schoolName" Label="@LabelNames.SchoolName.GetLabelText()" Required="true" MaxLength="200" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonEducationCommand.SchoolName))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonEducationCommand.SchoolName))" />
                    <MudTextField @bind-Value="_field" Label="@LabelNames.Field.GetLabelText()" MaxLength="200" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonEducationCommand.Field))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonEducationCommand.Field))" />
                    <MudStack Row="true" Spacing="2">
                        <MudDatePicker @bind-Date="_fromDate" Label="@LabelNames.FromDate.GetLabelText()" Required="true" DateFormat="yyyy-MM-dd" Class="flex-grow-1" />
                        <MudDatePicker @bind-Date="_toDate" Label="@LabelNames.ToDate.GetLabelText()" Required="true" DateFormat="yyyy-MM-dd" Class="flex-grow-1" />
                    </MudStack>
                    <MudTextField @bind-Value="_degree" Label="@LabelNames.Degree.GetLabelText()" Required="true" MaxLength="100" Immediate="true"
                                  Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonEducationCommand.Degree))"
                                  ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonEducationCommand.Degree))" />
                    <MudTextField @bind-Value="_specialization" Label="@LabelNames.Specialization.GetLabelText()" MaxLength="200" Immediate="true" />
                    <MudTextField @bind-Value="_thesisTitle" Label="@LabelNames.ThesisTitle.GetLabelText()" MaxLength="300" Immediate="true" />
                    <MudTextField @bind-Value="_grade" Label="@LabelNames.Grade.GetLabelText()" MaxLength="50" Immediate="true" />
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@LabelNames.ButtonCancel.GetLabelText()</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_saving || _loading || !_isValid)" OnClick="SaveAsync">
            @(_saving ? LabelNames.StatusSaving.GetLabelText() : LabelNames.ButtonSave.GetLabelText())
        </MudButton>
    </DialogActions>
</MudDialog>