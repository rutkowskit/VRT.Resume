<MudDialog DefaultFocus="DefaultFocus.FirstChild" DisableBackdropClick="true">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isNew ? "Add duty" : "Edit duty")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudTextField @bind-Value="_name" Label="Duty" Required="true" MaxLength="500" Immediate="true"
                              Error="FieldErrors.HasFieldError(_fieldErrors, nameof(UpsertPersonExperienceDutyCommand.Name))"
                              ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(UpsertPersonExperienceDutyCommand.Name))" />
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_saving || _loading || !_isValid)" OnClick="SaveAsync">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>