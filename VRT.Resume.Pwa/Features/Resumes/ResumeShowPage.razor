
@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!string.IsNullOrEmpty(_loadError))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
    <MudIconButtonWithTitle Icon="@Icons.Material.Outlined.ArrowBack"
                            Href="@Routes.Home"
                            Title="@LabelNames.BackToResumes.GetLabelText()"
                            Class="resume-show-back mt-2" />
}
else if (_resume is not null)
{
    <HeadContent>
        <link rel="stylesheet" href="@_activeTemplate.CssPath" />
    </HeadContent>

    <div class="resume-show-page">
    <div class="resume-show-toolbar resume-print-toolbar">
        <MudIconButtonWithTitle Icon="@Icons.Material.Outlined.ArrowBack"
                                Href="@Routes.Home"
                                Title="@LabelNames.BackToResumes.GetLabelText()"
                                Class="resume-show-back" />
        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Spacing="2"
                  Wrap="Wrap.Wrap"
                  Class="resume-show-toolbar__actions">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Print"
                       OnClick="PrintAsync">
                @LabelNames.ButtonPrint.GetLabelText()
            </MudButton>
            <MudSelect T="string"
                       Label="@LabelNames.ResumeTemplateLabel.GetLabelText()"
                       Value="_selectedTemplateId"
                       ValueChanged="OnTemplateChangedAsync"
                       Dense="true"
                       Margin="Margin.Dense"
                       Style="min-width: 12rem; max-width: 16rem;">
                @foreach (var template in _templates)
                {
                    <MudSelectItem Value="@template.Id">@template.LabelName.GetLabelText()</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </div>

    <div class="overflow-container resume-document-preview">
        <DynamicComponent Type="_activeTemplate.ComponentType" Parameters="_documentParameters" />
    </div>
    </div>
}