@inherits ResumeDocumentBase
<div class="resume page-a4 resume-template-linear">
    <div class="resume-linear-body">
        <header class="resume-linear-header">
            <h1 class="resume-linear-name">@Model.FirstName @Model.LastName</h1>
            <p class="resume-linear-position">@Model.Position</p>
            <ResumeInlineContactLine Contacts="@Model.Contact" />
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.Summary))
        {
            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeProfile.GetLabelText()</h2>
                    <p class="resume-summary">@Model.Summary</p>
                </div>
            </section>
        }

        <ResumeExperienceSection Experience="@OrderedExperience" />
        <ResumeEducationSection Education="@OrderedEducation" />

        @{
            var technicalSkills = ResumeDisplayHelpers.GetTechnicalSkills(Model.Skills).ToArray();
        }
        @if (technicalSkills.Length > 0)
        {
            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeTechSkills.GetLabelText()</h2>
                    <p class="resume-skills-inline">
                        @foreach (var skill in technicalSkills)
                        {
                            <span class="@ResumeDisplayHelpers.SkillCssClass(skill, "resume-skill-item")">@skill.Name</span>
                        }
                    </p>
                </div>
            </section>
        }

        @{
            var softSkills = ResumeDisplayHelpers.GetSoftSkills(Model.Skills).ToArray();
        }
        @if (softSkills.Length > 0)
        {
            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeSoftSkills.GetLabelText()</h2>
                    <ul class="resume-skills-list">
                        @foreach (var skill in softSkills)
                        {
                            <li class="@ResumeDisplayHelpers.SkillCssClass(skill, string.Empty)">@skill.Name</li>
                        }
                    </ul>
                </div>
            </section>
        }

        @{
            var languages = ResumeDisplayHelpers.GetLanguageSkills(Model.Skills).ToArray();
        }
        @if (languages.Length > 0)
        {
            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeHumanLanguages.GetLabelText()</h2>
                    <p class="resume-languages-inline">
                        @foreach (var skill in languages)
                        {
                            <span class="@ResumeDisplayHelpers.SkillCssClass(skill, "resume-language-item")">
                                <span class="resume-language-name">@skill.Name</span><span class="resume-language-level">@skill.Level</span>
                            </span>
                        }
                    </p>
                </div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Permission))
        {
            <div class="resume-rodo">@Model.Permission</div>
        }
    </div>
</div>