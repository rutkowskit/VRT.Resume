@inherits CultureAwareComponentBase
<div class="resume page-a4 resume-template-classic">
    <div class="resume-container">
        <div class="resume-left-panel">
            <div class="resume-profile resume-card">
                <div class="resume-card-body">
                    @if (Model.ShowProfilePhoto)
                    {
                        <div class="resume-image-container">
                            <MudImage Src="@ProfileImageUrl"
                                      Class="resume-image"
                                      Alt="@LabelNames.Photo.GetLabelText()"
                                      ObjectFit="ObjectFit.Cover" />
                        </div>
                    }
                    <h1 class="resume-profile-name">@Model.FirstName @Model.LastName</h1>
                    <p class="resume-profile-position">@Model.Position</p>
                </div>
            </div>

            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeContact.GetLabelText()</h2>
                    @foreach (var contact in Model.Contact ?? [])
                    {
                        <div class="resume-contact-item">@ResumeDisplayHelpers.ContactLine(contact)</div>
                    }
                </div>
            </section>

            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeTechSkills.GetLabelText()</h2>
                    <div class="resume-skills-chips">
                        @foreach (var skill in ResumeDisplayHelpers.GetTechnicalSkills(Model.Skills))
                        {
                            <span class="@ResumeDisplayHelpers.SkillCssClass(skill, "chip")">@skill.Name</span>
                        }
                    </div>
                </div>
            </section>

            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeSoftSkills.GetLabelText()</h2>
                    <ul class="resume-work-resp">
                        @foreach (var skill in ResumeDisplayHelpers.GetSoftSkills(Model.Skills))
                        {
                            <li class="@ResumeDisplayHelpers.SkillCssClass(skill, string.Empty)">@skill.Name</li>
                        }
                    </ul>
                </div>
            </section>

            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeHumanLanguages.GetLabelText()</h2>
                    <div class="resume-language-list">
                        @foreach (var skill in ResumeDisplayHelpers.GetLanguageSkills(Model.Skills))
                        {
                            <div class="@ResumeDisplayHelpers.SkillCssClass(skill, "resume-language")">
                                <span class="resume-language-name">@skill.Name</span><span class="resume-language-level">@skill.Level</span>
                            </div>
                        }
                    </div>
                </div>
            </section>
        </div>

        <div class="resume-right-panel">
            <section class="resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeProfile.GetLabelText()</h2>
                    <p class="resume-summary">@Model.Summary</p>
                </div>
            </section>

            <section class="resume-experience resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeWorkExp.GetLabelText()</h2>
                    <div class="resume-work-list">
                        @foreach (var exp in OrderedExperience)
                        {
                            <div class="resume-work-item">
                                <div class="resume-timeline-item-title">
                                    @ResumeDisplayHelpers.FormatTimeRange(exp) — @exp.Position
                                </div>
                                <div class="resume-timeline-item-title-1">@exp.CompanyName</div>
                                <div class="resume-timeline-item-title-2">@exp.Location</div>
                                @if (exp.WorkActivities is { Length: > 0 })
                                {
                                    <ul class="resume-work-resp">
                                        @foreach (var activity in exp.WorkActivities)
                                        {
                                            <li>
                                                @activity.Description
                                                @{
                                                    var skills = ResumeDisplayHelpers.FormatActivitySkills(activity);
                                                }
                                                @if (skills is not null)
                                                {
                                                    @skills
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>

            <section class="resume-education resume-card resume-section">
                <div class="resume-card-body">
                    <h2 class="resume-section-title">@LabelNames.ResumeEducation.GetLabelText()</h2>
                    <div class="resume-education-list">
                        @foreach (var edu in OrderedEducation)
                        {
                            <div class="resume-edu-item">
                                <div class="resume-timeline-item-title">
                                    @ResumeDisplayHelpers.FormatTimeRange(edu, "yyyy") — @edu.Field
                                </div>
                                <div class="resume-timeline-item-title-1">@edu.SchoolName</div>
                                <div class="resume-timeline-item-title-2">
                                    @LabelNames.Degree.GetLabelText(): <span>@edu.Degree</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(edu.Specjalization))
                                {
                                    <div>@LabelNames.Specialization.GetLabelText(): <span>@edu.Specjalization</span></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(edu.ThesisTitle))
                                {
                                    <div>@LabelNames.Thesis.GetLabelText(): <span>@edu.ThesisTitle</span></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(edu.FinalGrade))
                                {
                                    <div>@LabelNames.Grade.GetLabelText(): <span>@edu.FinalGrade</span></div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Permission))
        {
            <div class="resume-rodo">@Model.Permission</div>
        }
    </div>
</div>