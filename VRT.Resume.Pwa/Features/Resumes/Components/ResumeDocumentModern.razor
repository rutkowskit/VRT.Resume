@inherits ResumeDocumentBase
<div class="resume page-a4 resume-template-modern">
    <div class="resume-modern-container">
        <aside class="resume-modern-sidebar">
            @if (Model.ShowProfilePhoto)
            {
                <div class="resume-modern-photo">
                    <div class="resume-image-container">
                        <MudImage Src="@ProfileImageUrl"
                                  Class="resume-image"
                                  Alt="@LabelNames.Photo.GetLabelText()"
                                  ObjectFit="ObjectFit.Cover" />
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Summary))
            {
                <section class="resume-card resume-section">
                    <div class="resume-card-body">
                        <h2 class="resume-section-title">@LabelNames.ResumeProfile.GetLabelText()</h2>
                        <p class="resume-summary">@Model.Summary</p>
                    </div>
                </section>
            }

            @{
                var sidebarSkills = ResumeDisplayHelpers.GetTechnicalSkills(Model.Skills)
                    .Concat(ResumeDisplayHelpers.GetSoftSkills(Model.Skills))
                    .ToArray();
            }
            @if (sidebarSkills.Length > 0)
            {
                <section class="resume-card resume-section">
                    <div class="resume-card-body">
                        <h2 class="resume-section-title">@LabelNames.ResumeTechSkills.GetLabelText()</h2>
                        <ul class="resume-modern-skills-list">
                            @foreach (var skill in sidebarSkills)
                            {
                                <li class="@ResumeDisplayHelpers.SkillCssClass(skill, string.Empty)">@skill.Name</li>
                            }
                        </ul>
                    </div>
                </section>
            }

            @{
                var languages = ResumeDisplayHelpers.GetLanguageSkills(Model.Skills).ToArray();
            }
            @if (languages.Length > 0)
            {
                <section class="resume-card resume-section">
                    <div class="resume-card-body">
                        <h2 class="resume-section-title">@LabelNames.ResumeHumanLanguages.GetLabelText()</h2>
                        <div class="resume-language-list">
                            @foreach (var skill in languages)
                            {
                                <div class="@ResumeDisplayHelpers.SkillCssClass(skill, "resume-language")">
                                    <span class="resume-language-name">@skill.Name</span><span class="resume-language-level">@skill.Level</span>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }
        </aside>

        <main class="resume-modern-main">
            <header class="resume-modern-header">
                <h1 class="resume-modern-name">@Model.FirstName @Model.LastName</h1>
                <p class="resume-modern-position">@Model.Position</p>
                @{
                    var contacts = (Model.Contact ?? []).ToArray();
                }
                @if (contacts.Length > 0)
                {
                    <div class="resume-modern-contact-grid">
                        @foreach (var contact in contacts)
                        {
                            <div class="resume-modern-contact-cell">
                                <span class="resume-modern-contact-label">@contact.Name</span>
                                <span class="resume-modern-contact-value">@ResumeDisplayHelpers.ContactValue(contact)</span>
                            </div>
                        }
                    </div>
                }
            </header>

            @{
                var experience = OrderedExperience.ToArray();
            }
            @if (experience.Length > 0)
            {
                <section class="resume-experience resume-card resume-section">
                    <div class="resume-card-body">
                        <h2 class="resume-section-title">@LabelNames.ResumeWorkExp.GetLabelText()</h2>
                        <div class="resume-work-list">
                            @foreach (var exp in experience)
                            {
                                <div class="resume-work-item">
                                    <div class="resume-modern-item-header">
                                        <span class="resume-modern-item-title">@exp.Position</span>
                                        <span class="resume-modern-item-dates">@ResumeDisplayHelpers.FormatTimeRange(exp)</span>
                                    </div>
                                    <div class="resume-modern-item-subtitle">@exp.CompanyName</div>
                                    @if (!string.IsNullOrWhiteSpace(exp.Location))
                                    {
                                        <div class="resume-modern-item-meta">@exp.Location</div>
                                    }
                                    @if (exp.WorkActivities is { Length: > 0 })
                                    {
                                        <ul class="resume-work-resp">
                                            @foreach (var activity in exp.WorkActivities)
                                            {
                                                <li>
                                                    @activity.Description
                                                    @{
                                                        var skills = ResumeDisplayHelpers.FormatActivitySkills(activity);
                                                    }
                                                    @if (skills is not null)
                                                    {
                                                        @skills
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }

            @{
                var education = OrderedEducation.ToArray();
            }
            @if (education.Length > 0)
            {
                <section class="resume-education resume-card resume-section">
                    <div class="resume-card-body">
                        <h2 class="resume-section-title">@LabelNames.ResumeEducation.GetLabelText()</h2>
                        <div class="resume-education-list">
                            @foreach (var edu in education)
                            {
                                <div class="resume-edu-item">
                                    <div class="resume-modern-item-header">
                                        <span class="resume-modern-item-title">@edu.Field</span>
                                        <span class="resume-modern-item-dates">@ResumeDisplayHelpers.FormatTimeRange(edu, "yyyy")</span>
                                    </div>
                                    <div class="resume-modern-item-subtitle">@edu.SchoolName</div>
                                    <div class="resume-modern-item-meta">
                                        @LabelNames.Degree.GetLabelText(): <span>@edu.Degree</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(edu.Specjalization))
                                    {
                                        <div class="resume-modern-item-detail">
                                            @LabelNames.Specialization.GetLabelText(): <span>@edu.Specjalization</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(edu.ThesisTitle))
                                    {
                                        <div class="resume-modern-item-detail">
                                            @LabelNames.Thesis.GetLabelText(): <span>@edu.ThesisTitle</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(edu.FinalGrade))
                                    {
                                        <div class="resume-modern-item-detail">
                                            @LabelNames.Grade.GetLabelText(): <span>@edu.FinalGrade</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Permission))
            {
                <div class="resume-rodo">@Model.Permission</div>
            }
        </main>
    </div>
</div>