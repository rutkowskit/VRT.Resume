@inherits CultureAwareComponentBase
<MudDialog DefaultFocus="DefaultFocus.FirstChild" Options="@PwaDialogOptions.LargeForm">
    <TitleContent>
        <MudText Typo="Typo.h6">@LabelNames.EditResumeSkillsTitle.GetLabelText()</MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_skills.Count == 0)
        {
            <MudText>@LabelNames.NoSkillsInPersonTab.GetLabelText()</MudText>
        }
        else
        {
            <div style="max-height: 60vh; overflow: auto;">
                <MudTable Items="_skills" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>@LabelNames.Name.GetLabelText()</MudTh>
                        <MudTh>@LabelNames.Type.GetLabelText()</MudTh>
                        <MudTh>@LabelNames.Relevant.GetLabelText()</MudTh>
                        <MudTh>@LabelNames.Hidden.GetLabelText()</MudTh>
                        <MudTh>@LabelNames.Position.GetLabelText()</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@LabelNames.Name.GetLabelText()">@context.Name</MudTd>
                        <MudTd DataLabel="@LabelNames.Type.GetLabelText()">@context.Type</MudTd>
                        <MudTd DataLabel="@LabelNames.Relevant.GetLabelText()">
                            <MudCheckBox @bind-Value="context.IsRelevant" Color="Color.Primary" />
                        </MudTd>
                        <MudTd DataLabel="@LabelNames.Hidden.GetLabelText()">
                            <MudCheckBox @bind-Value="context.IsHidden" Color="Color.Primary" />
                        </MudTd>
                        <MudTd DataLabel="@LabelNames.Position.GetLabelText()">
                            <MudNumericField @bind-Value="context.Position" Min="0" Max="999" HideSpinButtons="true" Style="max-width: 80px;" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@LabelNames.ButtonCancel.GetLabelText()</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanSave)" OnClick="SaveAsync">
            @(_saving ? LabelNames.StatusSaving.GetLabelText() : LabelNames.ButtonSave.GetLabelText())
        </MudButton>
    </DialogActions>
</MudDialog>
