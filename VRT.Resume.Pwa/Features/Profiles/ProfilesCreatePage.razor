@inherits CultureAwareComponentBase


<MudStack Spacing="4" Class="mud-width-full" Style="max-width: 480px;">
    <MudText Typo="Typo.h4">@LabelNames.PageCreateProfile.GetLabelText()</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary">
        @LabelNames.CreateProfilePageDescription.GetLabelText()
    </MudText>

    <MudForm @ref="_form" @bind-IsValid="_isValid" ValidationDelay="0">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_firstName"
                          @bind-Value:after="OnFieldChangedAsync"
                          Label="@LabelNames.FirstName.GetLabelText()"
                          Required="true"
                          RequiredError="@LabelNames.FirstNameRequired.GetLabelText()"
                          MaxLength="50"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.FirstName))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.FirstName))" />
            <MudTextField @bind-Value="_lastName"
                          @bind-Value:after="OnFieldChangedAsync"
                          Label="@LabelNames.LastName.GetLabelText()"
                          MaxLength="100"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.LastName))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.LastName))" />
            <MudTextField @bind-Value="_email"
                          @bind-Value:after="OnFieldChangedAsync"
                          Label="@LabelNames.EmailOptional.GetLabelText()"
                          InputType="InputType.Email"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.Email))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.Email))" />
        </MudStack>
    </MudForm>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(_submitting || !_isValid)"
                   OnClick="CreateProfileAsync">
            @(_submitting ? LabelNames.StatusCreating.GetLabelText() : LabelNames.ButtonCreateProfile.GetLabelText())
        </MudButton>
        <MudButton Variant="Variant.Text" Href="@Routes.Profiles.List">@LabelNames.ButtonCancel.GetLabelText()</MudButton>
    </MudStack>
</MudStack>
