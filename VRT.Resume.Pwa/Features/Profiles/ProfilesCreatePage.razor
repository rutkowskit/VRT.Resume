@page "/profiles/create"
@implements IProfileExemptPage
@using VRT.Resume.Application.Persons.Commands.CreatePersonAccount
@inject MediatorSender Mediator
@inject DummyCurrentUserService ProfileContext
@inject NavigationManager Navigation

<PageTitle>Create profile</PageTitle>

<MudStack Spacing="4" Class="mud-width-full" Style="max-width: 480px;">
    <MudText Typo="Typo.h4">Create profile</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary">
        Add a new local profile. You can switch between profiles at any time.
    </MudText>

    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_firstName"
                          Label="First name"
                          Required="true"
                          RequiredError="First name is required"
                          MaxLength="50"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.FirstName))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.FirstName))" />
            <MudTextField @bind-Value="_lastName"
                          Label="Last name"
                          MaxLength="100"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.LastName))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.LastName))" />
            <MudTextField @bind-Value="_email"
                          Label="Email (optional)"
                          InputType="InputType.Email"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.Email))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.Email))" />
        </MudStack>
    </MudForm>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(_submitting || !_isValid)"
                   OnClick="CreateProfileAsync">
            @(_submitting ? "Creating…" : "Create profile")
        </MudButton>
        <MudButton Variant="Variant.Text" Href="profiles">Cancel</MudButton>
    </MudStack>
</MudStack>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _submitting;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string? _email;
    private IReadOnlyDictionary<string, string[]> _fieldErrors = new Dictionary<string, string[]>();

    private async Task CreateProfileAsync()
    {
        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid)
                return;
        }

        _submitting = true;
        _fieldErrors = new Dictionary<string, string[]>();

        var userId = $"local:{Guid.NewGuid():N}";
        var outcome = await Mediator.SendAsync(new CreatePersonAccountCommand
        {
            UserId = userId,
            FirstName = _firstName.Trim(),
            LastName = _lastName.Trim(),
            Email = string.IsNullOrWhiteSpace(_email) ? null : _email.Trim(),
        });

        _fieldErrors = outcome.FieldErrors;

        if (outcome.Result.IsFailure)
        {
            _submitting = false;
            return;
        }

        await ProfileContext.SetContextAsync(userId);
        Navigation.NavigateTo("/");
    }
}