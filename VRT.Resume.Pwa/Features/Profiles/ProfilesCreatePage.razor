<PageTitle>Create profile</PageTitle>

<MudStack Spacing="4" Class="mud-width-full" Style="max-width: 480px;">
    <MudText Typo="Typo.h4">Create profile</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary">
        Add a new local profile. You can switch between profiles at any time.
    </MudText>

    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_firstName"
                          Label="First name"
                          Required="true"
                          RequiredError="First name is required"
                          MaxLength="50"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.FirstName))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.FirstName))" />
            <MudTextField @bind-Value="_lastName"
                          Label="Last name"
                          MaxLength="100"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.LastName))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.LastName))" />
            <MudTextField @bind-Value="_email"
                          Label="Email (optional)"
                          InputType="InputType.Email"
                          Immediate="true"
                          Error="FieldErrors.HasFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.Email))"
                          ErrorText="@FieldErrors.GetFieldError(_fieldErrors, nameof(CreatePersonAccountCommand.Email))" />
        </MudStack>
    </MudForm>

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(_submitting || !_isValid)"
                   OnClick="CreateProfileAsync">
            @(_submitting ? "Creating…" : "Create profile")
        </MudButton>
        <MudButton Variant="Variant.Text" Href="@Routes.Profiles.List">Cancel</MudButton>
    </MudStack>
</MudStack>